generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // connection is handled in prisma.ts go there :)
}

model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  passwordHash       String
  browserLockEnabled Boolean     @default(false)
  lockedTabs         LockedTab[]
  sessions           Session[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@map("users")
}

model LockedTab {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  urlPattern String
  label      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("locked_tabs")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jwtJti    String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([jwtJti])
  @@map("sessions")
}
